   RowBox[{"{", 
    RowBox[{"$HomeDirectory", ",", "\"\</PATH TO REPOSITORY FOLDER\>\""}], 
    "}"}], "]"}]}]], "Input",ExpressionUUID->"9473544d-b51d-450e-b389-\
6bb5945ce986"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Basic", " ", "constants"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[CurlyEpsilon]", "=", "0.05"}], ";"}], 
   "                             ", 
   RowBox[{"(*", 
    RowBox[{"acceptable", " ", "ruin", " ", "probability"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[CurlyPhi]", "=", 
     RowBox[{"InverseCDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", 
       RowBox[{"1", "-", 
        RowBox[{"\[CurlyEpsilon]", "/", "2"}]}]}], "]"}]}], ";"}], "   ", 
   RowBox[{"(*", " ", 
    RowBox[{"\[TildeTilde]", "1.95996"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Full", " ", "ruin", " ", "equation", " ", "f", 
     RowBox[{"(", 
      RowBox[{"x", "|", "a"}], ")"}]}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "f", "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"CDFN", "[", "z_", "]"}], ":=", 
     RowBox[{"CDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", "z"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x_", ",", "a_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], " ", "a", " ", "x"}], "]"}], " ", 
       RowBox[{"CDFN", "[", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"x", "-", "a"}], ")"}]}], "]"}]}], "+", 
      RowBox[{"CDFN", "[", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"x", "+", "a"}], ")"}]}], "]"}], "-", "\[CurlyEpsilon]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Exact", " ", "root", " ", "SExact", 
     RowBox[{"(", "a", ")"}], " ", "with", " ", "adaptive", " ", "starting", " ",
      "guess"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SExact", "[", 
     RowBox[{"a_", "?", "NumericQ"}], "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"xSeed", ",", "sol"}], "}"}], ",", 
      RowBox[{
       RowBox[{"xSeed", "=", 
        RowBox[{"If", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"a", "<", "\[CurlyPhi]"}], ",", "\[CurlyPhi]", ",", 
          RowBox[{"(*", 
           RowBox[{"diffusion", " ", "seed"}], "*)"}], "\[IndentingNewLine]", 
          
          RowBox[{
           RowBox[{"Log", "[", 
            RowBox[{"1", "/", "\[CurlyEpsilon]"}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "a"}], ")"}]}]}], "          ", 
         RowBox[{"(*", 
          RowBox[{"drift", " ", "seed"}], "*)"}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sol", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"FindRoot", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"f", "[", 
             RowBox[{"x", ",", "a"}], "]"}], "==", "0"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "xSeed"}], "}"}], ",", 
           RowBox[{"WorkingPrecision", "->", "30"}], ",", 
           RowBox[{"AccuracyGoal", "->", "15"}], ",", 
           RowBox[{"PrecisionGoal", "->", "15"}]}], "\[IndentingNewLine]", 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatchQ", "[", 
          RowBox[{"sol", ",", 
           RowBox[{"{", 
            RowBox[{"_", "->", "_"}], "}"}]}], "]"}], ",", 
         RowBox[{"x", "/.", " ", "sol"}], ",", 
         RowBox[{"Missing", "[", "\"\<noRoot\>\"", "]"}]}], 
        "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Two", " ", "asymptotic", " ", "formulas", " ", 
     RowBox[{"(", 
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"\[Sqrt]", "\[Tau]"}], " ", "normalised", " ", "to", " ", 
       "1"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Sdiff", "[", "a_", "]"}], ":=", "\[CurlyPhi]"}], ";"}], 
   "                       ", 
   RowBox[{"(*", 
    RowBox[{"diffusion", " ", "approximation"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Sdrift", "[", "a_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{"1", "/", "\[CurlyEpsilon]"}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", "a"}], ")"}]}]}], ";"}], "          ", 
   RowBox[{"(*", 
    RowBox[{"drift", " ", "approximation"}], "*)"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"::", "Section", "::"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Evaluate", " ", "over", " ", "a", " ", "grid", " ", "of", " ", "a"}], "-",
      "values"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aVals", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0.1", ",", "10", ",", "0.1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"exact", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Log10", "[", "a", "]"}], ",", 
         RowBox[{"Log10", "[", 
          RowBox[{"SExact", "[", "a", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "aVals"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"diffApp", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Log10", "[", "a", "]"}], ",", 
         RowBox[{"Log10", "[", 
          RowBox[{"Sdiff", "[", "a", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "aVals"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"driftApp", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Log10", "[", "a", "]"}], ",", 
         RowBox[{"Log10", "[", 
          RowBox[{"Sdrift", "[", "a", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "aVals"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Remove", " ", "any", " ", "points", " ", "where", " ", "FindRoot", " ", 
     "failed"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"exact", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{"exact", ",", 
       RowBox[{"{", 
        RowBox[{"_", ",", "_Missing"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Plot", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"diffdriftplot", " ", "=", " ", 
    RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"exact", ",", 
        RowBox[{"(*", 
         RowBox[{"black", "\[Dash]", 
          RowBox[{"exact", " ", "root"}]}], "*)"}], "\[IndentingNewLine]", 
        "diffApp", ",", 
        RowBox[{"(*", 
         RowBox[{"blue", "\[Dash]", 
          RowBox[{"diffusion", " ", "approx"}]}], "*)"}], 
        "\[IndentingNewLine]", "driftApp"}], "       ", 
       RowBox[{"(*", 
        RowBox[{"red", "\[Dash]", 
         RowBox[{"drift", " ", "approx"}]}], "*)"}], "\[IndentingNewLine]", 
       "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Black", ",", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", "Thick"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Red", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"Placed", "[", 
        RowBox[{
         RowBox[{"{", 
          
          RowBox[{"\"\<Exact solution\>\"", ",", "\"\<Diffusion dominated\>\"",
            ",", "\"\<Drift dominated\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Scaled", "[", 
            RowBox[{"{", 
             RowBox[{"0.01", ",", "0.25"}], "}"}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0.7"}], "}"}]}], "}"}]}], "]"}]}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<\!\(\*SubscriptBox[\(log\), \(10\)]\) \!\(\*StyleBox[\"a\
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"=\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[OverscriptBox[StyleBox[SubscriptBox[\
\"g\", \"S\"],FontSlant->\"Italic\"], \
\"^\"],FontSlant->\"Italic\"]\)\!\(\*StyleBox[SqrtBox[\"\[Tau]\"],FontSlant->\
\"Italic\"]\)\!\(\*StyleBox[\"/\",FontSlant->\"Italic\"]\)\[Sigma]\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(log\), \(10\)]\) \
\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \",FontSlant->\
\"Italic\"]\)\!\(\*StyleBox[\"=\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[SubscriptBox[StyleBox[\"S\",\
FontSlant->\"Italic\"], \
\"0\"],FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"/\",FontSlant->\"Italic\"]\)\!\
\(\*StyleBox[\"\[Sigma]\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[SqrtBox[\"\
\[Tau]\"],FontSlant->\"Italic\"]\)\>\""}], "}"}]}], ",", 
      RowBox[{"LabelStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"FontSize", "->", "16"}]}], "]"}]}], ",", 
      RowBox[{"ImageSize", "->", "520"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9627300617791033`*^9, 3.962730061780325*^9}, {
