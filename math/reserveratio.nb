Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"your", " ", "density", " ", "plot"}], ",", 
    RowBox[{
    "unchanged", " ", "except", " ", "wrapped", " ", "in", " ", "a", " ", 
     "symbol", " ", "so", " ", "we", " ", "can", " ", "reuse", " ", "it"}]}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dp", "=", 
     RowBox[{"DensityPlot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "@", 
        RowBox[{"(", 
         RowBox[{"phidem", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"gammastar", "->", "1.17"}], ",", 
            RowBox[{"demcost", "->", "0.24"}]}], "}"}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"g1", ",", "0.6", ",", "1.2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c1", ",", "0.6", ",", "1"}], "}"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Gain exponent, \!\(\*StyleBox[SubscriptBox[\"g\", \
\"1\"],FontSlant->\"Italic\"]\)\>\"", 
          ",", "\"\<Cost exponent, \!\(\*StyleBox[SubscriptBox[\"c\", \
\"1\"],FontSlant->\"Italic\"]\)\>\""}], "}"}]}], ",", 
       RowBox[{"LabelStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", 
          RowBox[{"FontSize", "->", "16"}]}], "]"}]}], ",", 
       RowBox[{"MeshFunctions", "->", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"g1", ",", "c1", ",", "z"}], "}"}], ",", 
          RowBox[{"g1", "-", "c1"}]}], "]"}]}], ",", 
       RowBox[{"Mesh", "->", 
        RowBox[{"{", 
         RowBox[{"{", "0", "}"}], "}"}]}], ",", 
       RowBox[{"MeshStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "White", ",", "Dashed"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"BarLegend", "[", 
           RowBox[{"Automatic", ",", 
            RowBox[{"LegendLabel", "->", 
             RowBox[{
             "Style", 
              "[", "\"\<\!\(\*SuperscriptBox[\(\[Phi]\), \(dem\)]\)\>\"", 
              "]"}]}]}], "]"}], ",", "Right"}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cols", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"ColorData", "[", 
        RowBox[{"86", ",", "i"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "4"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "turn", " ", "each", " ", "point", " ", "into", " ", "a", " ", "coloured",
      " ", "primitive"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"pts", "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"#1", ",", 
           RowBox[{"PointSize", "[", "0.025", "]"}], ",", 
           RowBox[{"Point", "[", "#2", "]"}]}], "}"}], "&"}], ",", 
        RowBox[{"{", 
         RowBox[{"cols", ",", "g1c1coords"}], "}"}]}], "]"}]}], ";"}], "*)"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coords", "=", "g1c1coords"}], ";"}], "                ", 
   RowBox[{"(*", 
    RowBox[{"just", " ", "to", " ", "shorten", " ", "the", " ", "name"}], 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"overlay", "=", 
      RowBox[{"Graphics", "@", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "0.052", "]"}], ",", 
           RowBox[{"Point", "[", "coords", "]"}]}], "}"}], ",", 
         RowBox[{"MapThread", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"#1", ",", 
              RowBox[{"PointSize", "[", "0.04", "]"}], ",", 
              RowBox[{"Point", "[", "#2", "]"}]}], "}"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{"cols", ",", "coords"}], "}"}]}], "]"}]}], 
        "\[IndentingNewLine]", "]"}]}]}], ";"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"overlay", "=", 
      RowBox[{"Graphics", "@", 
       RowBox[{"MapThread", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"EdgeForm", "[", 
             RowBox[{"{", 
              RowBox[{"Thick", ",", "Black"}], "}"}], "]"}], ",", "#1", ",", 
            RowBox[{"Disk", "[", 
             RowBox[{"#2", ",", "0.01"}], "]"}]}], "}"}], "&"}], ",", 
         RowBox[{"{", 
          RowBox[{"cols", ",", "coords"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"overlay", "=", 
     RowBox[{"Graphics", "@", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"EdgeForm", "[", 
            RowBox[{"{", 
             RowBox[{"Thick", ",", "Black"}], "}"}], "]"}], ",", "#1", ",", 
           RowBox[{"Disk", "[", 
            RowBox[{"#2", ",", 
             RowBox[{"Offset", "[", "6", "]"}]}], "]"}]}], "}"}], "&"}], ",", 
        
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"6", " ", "pt"}], "\[TildeTilde]", 
          RowBox[{"2", " ", "mm"}]}], "*)"}], 
        RowBox[{"{", 
         RowBox[{"cols", ",", "coords"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"ReserveRatioDemPlot", " ", "=", " ", 
    RowBox[{"Show", "[", "\[IndentingNewLine]", 
     RowBox[{
     "dp", ",", "\[IndentingNewLine]", "overlay", ",", "\[IndentingNewLine]", 
      
      RowBox[{"Graphics", "[", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\[Zeta] = 2.15\>\"", ",", 
           RowBox[{"FontSize", "->", "18"}], ",", " ", "White"}], "]"}], ",", 
         
         RowBox[{"{", 
          RowBox[{"0.91", ",", "0.73"}], "}"}]}], "]"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Graphics", "[", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<\[Zeta] \[LessEqual] 2.00\>\"", ",", 
           RowBox[{"FontSize", "->", "18"}], ",", " ", "White"}], "]"}], ",", 
         
         RowBox[{"{", 
          RowBox[{"0.99", ",", "0.815"}], "}"}]}], "]"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ImageSize", "->", "400"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", "optional"}], " ", 
      RowBox[{"labels", "--"}], " ", "Black"}], ",", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Callout", "[", 
          RowBox[{"#1", ",", 
           RowBox[{"Style", "[", 
            RowBox[{"#2", ",", "14"}], "]"}]}], "]"}], ")"}], "&"}], ",", 
