Cell[BoxData[
 RowBox[{"DensityPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"(", 
     RowBox[{"phidem", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"gammastar", "->", "1.17"}], ",", 
        RowBox[{"demcost", "->", "0.24"}]}], "}"}]}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"g1", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"c1", ",", "0", ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Gain exponent, \!\(\*StyleBox[SubscriptBox[\"g\", \
\"1\"],FontSlant->\"Italic\"]\)\>\"", 
      ",", "\"\<Cost exponent, \!\(\*StyleBox[SubscriptBox[\"c\", \
\"1\"],FontSlant->\"Italic\"]\)\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"FontSize", "->", "16"}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "draw"}]}], " ", "the", " ", "boundary", " ", "g1"}], "==", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"c1", "--"}], "--"}], "--"}], "--"}], "--"}], 
                "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
         "--"}], "--"}], "--"}], "--"}]}], "*)"}], 
   RowBox[{"MeshFunctions", "->", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"g1", ",", "c1", ",", "z"}], "}"}], ",", 
      RowBox[{"g1", "-", "c1"}]}], "]"}]}], ",", 
   RowBox[{"(*", 
    RowBox[{"what", " ", "to", " ", "contour"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Mesh", "->", 
    RowBox[{"{", 
     RowBox[{"{", "0", "}"}], "}"}]}], ",", 
   RowBox[{"(*", 
    RowBox[{"the", " ", "value", " ", "to", " ", "contour"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"MeshStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Thick", ",", "Black", ",", "Dashed"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "colour", " ", "bar", " ", "with", " ", "its", " ", "own", " ", "label"}],
     "*)"}], 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"BarLegend", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{"LegendLabel", "->", 
         RowBox[{
         "Style", "[", "\"\<\!\(\*SuperscriptBox[\(\[Phi]\), \(dem\)]\)\>\"", 
          "]"}]}]}], "   ", 
       RowBox[{"(*", 
        RowBox[{
        "what", " ", "to", " ", "print", " ", "beside", " ", "the", " ", 
         "bar"}], "*)"}], "]"}], ",", "Right"}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
